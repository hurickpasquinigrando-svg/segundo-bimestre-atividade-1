8.
programa
{
    funcao inicio()
    {
        cadeia mae, filha, aux

        // Valores iniciais
        mae = "Tess"
        filha = "Anna"

        escreva("Antes da troca:\n")
        escreva("Mãe: ", mae, "\n")
        escreva("Filha: ", filha, "\n\n")

        // Troca dos valores
        aux = mae
        mae = filha
        filha = aux

        escreva("Depois da troca:\n")
        escreva("Mãe: ", mae, "\n")
        escreva("Filha: ", filha)
    }
}
   fiz e acho que deu certo
